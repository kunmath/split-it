NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=https://placeholder.invalid

NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
