# Copy this file to .env.local before running docker compose.
# Blank Clerk values keep auth in placeholder mode, disable live sign-in/sign-up,
# and leave app routes public so the Docker stack still boots cleanly.

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=https://placeholder.invalid

NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
